# SignalForge — environment variables
# =============================================================

# LLM — OpenRouter (required)
OPENROUTER_API_KEY=your_openrouter_key_here

# Alpaca Market Data (required)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# PostgreSQL (required)
DATABASE_URL=postgresql+asyncpg://signalforge:signalforge_pass@localhost:5432/signalforge

# Redis (required)
REDIS_URL=redis://localhost:6379

# StockTwits credentials (optional)
# Tier 1: Firestream API (requires credentials)
# Tier 2: Public Stream API (free, no credentials needed)
# Parses last 30 posts for user-tagged bullish/bearish sentiment.
# If USERNAME/PASSWORD are blank, the free public stream is used automatically.
# ~30-50% of posts carry explicit sentiment tags; the rest count toward neutral.
# Leave both blank for public stream (no setup needed).

STOCKTWITS_USERNAME=
STOCKTWITS_PASSWORD=
STOCKTWITS_ACCESS_TOKEN=

# Optional enrichment
ALPHA_VANTAGE_KEY=
FRED_API_KEY=
NEWS_API_KEY=

# App
ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO