# SignalForge — environment variables
# =============================================================

# LLM — OpenRouter (required)
OPENROUTER_API_KEY=your_openrouter_key_here

# Alpaca Market Data (required)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# PostgreSQL (required)
DATABASE_URL=postgresql+asyncpg://signalforge:signalforge_pass@localhost:5432/signalforge

# Redis (required)
REDIS_URL=redis://localhost:6379

# StockTwits API (optional - public stream works without credentials)
# Parses last 30 posts for user-tagged bullish/bearish sentiment.
# ~30-50% of posts carry explicit sentiment tags; the rest count toward neutral.
# Leave blank to use the free public stream (no setup needed).

STOCKTWITS_ACCESS_TOKEN=

# TipRanks MCP API (free tier — 5 req/min, 50 req/month)
# Provides analyst ratings, price targets, and consensus for stocks.
# Get your free API key from: https://mcp.tipranks.com
TIPRANKS_API_KEY=

# Optional enrichment
ALPHA_VANTAGE_KEY=
FRED_API_KEY=
NEWS_API_KEY=

# App
ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO